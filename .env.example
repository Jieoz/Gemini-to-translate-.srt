# Copy this file to .env and fill in your real key(s)

# Provider: gemini | openai_compat
API_PROVIDER=gemini

# Official Gemini
GEMINI_API_KEY=

# OpenAI-compatible third-party API
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=gpt-4o-mini
# Optional: comma-separated selectable models shown in UI/config
OPENAI_COMPAT_MODELS=gpt-4o-mini
